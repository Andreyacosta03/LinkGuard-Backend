# Global Settings
* text=auto eol=lf

# JavaScript / TypeScript (Node.js)
*.js      text eol=lf
*.ts      text eol=lf
*.mjs     text eol=lf
*.cjs     text eol=lf
*.json    text eol=lf

# Server and Runtime Configuration
.env            text eol=lf
.env.*          text eol=lf
.editorconfig   text eol=lf
.gitignore      text eol=lf
.gitattributes  text eol=lf
Procfile        text eol=lf
Dockerfile      text eol=lf
docker-compose.yml text eol=lf

# Documentation and Data
*.md      text eol=lf
*.yml     text eol=lf
*.yaml    text eol=lf
*.sql     text eol=lf
*.graphql text eol=lf

# Lockfiles
package-lock.json text eol=lf
pnpm-lock.yaml    text eol=lf
yarn.lock         text eol=lf

# Automation Scripts
*.sh      text eol=lf

# Binary Files (Assets or Logs)
*.png     binary
*.jpg     binary
*.jpeg    binary
*.pdf     binary
*.ico     binary
*.svg     text eol=lf
*.log     text eol=lf
